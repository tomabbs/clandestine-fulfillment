# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_xxx

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=clandestine-fulfillment
SENTRY_AUTH_TOKEN=sntrys_xxx

# Shopify (main Clandestine catalog — NOT client stores)
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2026-01
SHOPIFY_WEBHOOK_SECRET=

# Shopify OAuth (client store connections)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Squarespace OAuth (client store connections)
SQUARESPACE_CLIENT_ID=
SQUARESPACE_CLIENT_SECRET=

# Discogs OAuth (client store connections) + master catalog
# NOTE: DISCOGS_MASTER_ACCESS_TOKEN is set via /admin/discogs/credentials UI, not here
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_MASTER_ACCESS_TOKEN=

# EasyPost (label creation + SCAN forms)
EASYPOST_API_KEY=

# ShipStation (legacy — kept for historical data, no longer actively used)
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=
SHIPSTATION_WEBHOOK_SECRET=

# AfterShip
AFTERSHIP_API_KEY=xxx
AFTERSHIP_WEBHOOK_SECRET=xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Bandcamp
BANDCAMP_CLIENT_ID=xxx
BANDCAMP_CLIENT_SECRET=xxx

# Resend
RESEND_API_KEY=re_xxx
RESEND_INBOUND_WEBHOOK_SECRET=whsec_xxx

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
